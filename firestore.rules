rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStatus(status) {
      return status == 'pending'
        || status == 'accepted'
        || status == 'refused'
        || status == 'cancelled';
    }

    function isValidActivityStatus(status) {
      return status == 'open'
        || status == 'full'
        || status == 'cancelled'
        || status == 'done';
    }

    function isValidActivityVisibility(visibility) {
      return visibility == 'public'
        || visibility == 'private'
        || visibility == 'inviteOnly';
    }

    function isValidParticipantVisibility(value) {
      return value == 'participants_only'
        || value == 'public'
        || value == 'owner_only'
        || value == 'friends';
    }

    function activityPath(activityId) {
      return /databases/$(database)/documents/activities/$(activityId);
    }

    function participantPath(activityId, userId) {
      return /databases/$(database)/documents/activities/$(activityId)/participants/$(userId);
    }

    function activityDoc(activityId) {
      return get(activityPath(activityId));
    }

    function isActivityOwner(activityId) {
      return isAuthenticated()
        && activityDoc(activityId).data.ownerId == request.auth.uid;
    }

    function isParticipant(activityId) {
      return isAuthenticated()
        && exists(participantPath(activityId, request.auth.uid));
    }

    function isParticipantAfter(activityId) {
      return isAuthenticated()
        && existsAfter(participantPath(activityId, request.auth.uid));
    }

    function isActivityMember(activityId) {
      return isActivityOwner(activityId) || isParticipant(activityId);
    }

    function isActivityMemberAfter(activityId) {
      return isActivityOwner(activityId) || isParticipantAfter(activityId);
    }

    function groupPath(groupId) {
      return /databases/$(database)/documents/groups/$(groupId);
    }

    function groupDoc(groupId) {
      return get(groupPath(groupId));
    }

    function hasGroupId(data) {
      return 'groupId' in data
        && data.groupId is string
        && data.groupId.size() > 0;
    }

    function isGroupOwner(groupId) {
      return isAuthenticated()
        && groupDoc(groupId).data.ownerId == request.auth.uid;
    }

    function isGroupMemberById(groupId) {
      return isAuthenticated()
        && groupDoc(groupId).data.memberIds is list
        && request.auth.uid in groupDoc(groupId).data.memberIds;
    }

    function canReadActivity(activityId, data) {
      return isAuthenticated()
        && (
          data.visibility == 'public'
          || data.ownerId == request.auth.uid
          || isParticipant(activityId)
          || (
            hasGroupId(data)
            && isGroupMemberById(data.groupId)
          )
        );
    }

    function isValidActivityCreate() {
      return isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdById == request.auth.uid
        && request.resource.data.ownerPending == false
        && request.resource.data.participantCount is int
        && request.resource.data.participantCount == 1
        && request.resource.data.maxParticipants is int
        && request.resource.data.maxParticipants >= 0
        && isValidActivityStatus(request.resource.data.status)
        && isValidActivityVisibility(request.resource.data.visibility)
        && (
          !('participantVisibility' in request.resource.data)
          || isValidParticipantVisibility(request.resource.data.participantVisibility)
        )
        && (
          !hasGroupId(request.resource.data)
          || isGroupMemberById(request.resource.data.groupId)
        );
    }

    function isLimitedOwnerActivityUpdate() {
      return isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdById == resource.data.createdById
        && request.resource.data.participantCount == resource.data.participantCount
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'location',
          'updatedAt'
        ]);
    }

    function isFullOwnerActivityUpdate() {
      return isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && resource.data.participantCount <= 1
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdById == resource.data.createdById
        && request.resource.data.participantCount == resource.data.participantCount
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'description',
          'category',
          'day',
          'startTime',
          'endTime',
          'startDateTime',
          'endDateTime',
          'location',
          'maxParticipants',
          'level',
          'groupType',
          'visibility',
          'status',
          'updatedAt',
          'createdById',
          'createdByPseudo'
        ])
        && request.resource.data.maxParticipants is int
        && request.resource.data.maxParticipants >= 0
        && isValidActivityStatus(request.resource.data.status)
        && isValidActivityVisibility(request.resource.data.visibility);
    }

    function isOperationalActivityUpdate(activityId) {
      return isAuthenticated()
        && (
          isActivityMember(activityId)
          || isActivityMemberAfter(activityId)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantCount',
          'status',
          'updatedAt',
          'lastMessageText',
          'lastMessageAt'
        ])
        && request.resource.data.participantCount is int
        && request.resource.data.participantCount >= 0
        && isValidActivityStatus(request.resource.data.status);
    }

    function isOwnerLeaveAndOfferOwnershipUpdate(activityId) {
      return isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && isParticipant(activityId)
        && resource.data.participantCount > 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantCount',
          'ownerId',
          'ownerPseudo',
          'ownerPending',
          'createdById',
          'createdByPseudo',
          'status',
          'lastMessageText',
          'lastMessageAt',
          'updatedAt'
        ])
        && request.resource.data.ownerId == ''
        && request.resource.data.ownerPseudo == ''
        && request.resource.data.ownerPending == true
        && request.resource.data.participantCount == resource.data.participantCount - 1
        && isValidActivityStatus(request.resource.data.status);
    }

    function isActivityOwnershipClaimUpdate(activityId) {
      return isAuthenticated()
        && isParticipant(activityId)
        && resource.data.ownerPending == true
        && (!('ownerId' in resource.data) || resource.data.ownerId == '')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'ownerId',
          'ownerPseudo',
          'ownerPending',
          'reclaimedById',
          'reclaimedByPseudo',
          'reclaimedAt',
          'lastMessageText',
          'lastMessageAt',
          'updatedAt'
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.reclaimedById == request.auth.uid
        && request.resource.data.ownerPending == false;
    }

    function isValidTextMessageCreate(activityId) {
      return isAuthenticated()
        && isActivityMember(activityId)
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.type == 'text'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.keys().hasOnly([
          'senderId',
          'senderPseudo',
          'text',
          'type',
          'createdAt'
        ]);
    }

    function isActivitySystemMessageCreate(activityId) {
      return isAuthenticated()
        && isActivityMember(activityId)
        && request.resource.data.senderId == 'system'
        && request.resource.data.senderPseudo == 'Système'
        && request.resource.data.type == 'system'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.keys().hasOnly([
          'senderId',
          'senderPseudo',
          'text',
          'type',
          'createdAt'
        ]);
    }

    function isInvitationParticipant() {
      return isAuthenticated()
        && (
          resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid
        );
    }

    function isInvitationResponseUpdate() {
      return isAuthenticated()
        && resource.data.toUserId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt'
        ])
        && (
          request.resource.data.status == 'accepted'
          || request.resource.data.status == 'refused'
        );
    }

    function isInvitationCancelUpdate() {
      return isAuthenticated()
        && resource.data.fromUserId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt'
        ])
        && request.resource.data.status == 'cancelled';
    }

    function isGroupInvitationParticipant() {
      return isAuthenticated()
        && (
          resource.data.toUserId == request.auth.uid
          || resource.data.fromUserId == request.auth.uid
        );
    }

    function isGroupInvitationResponseUpdate() {
      return isAuthenticated()
        && resource.data.toUserId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt'
        ])
        && (
          request.resource.data.status == 'accepted'
          || request.resource.data.status == 'refused'
        );
    }

    function isGroupInvitationCancelUpdate() {
      return isAuthenticated()
        && resource.data.fromUserId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt'
        ])
        && request.resource.data.status == 'cancelled';
    }

    function canReadGroup(data) {
      return isAuthenticated()
        && (
          data.visibility == 'public'
          || data.ownerId == request.auth.uid
          || (
            data.memberIds is list
            && request.auth.uid in data.memberIds
          )
        );
    }

    function isOwnerGroupUpdate() {
      return isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'description',
          'visibility',
          'memberIds',
          'memberCount',
          'updatedAt'
        ])
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() >= 1
        && request.auth.uid in request.resource.data.memberIds;
    }

    function isValidSelfGroupJoinUpdate() {
      return isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'memberCount',
          'updatedAt'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.visibility == resource.data.visibility
        && request.resource.data.ownerPseudo == resource.data.ownerPseudo
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberIds is list
        && resource.data.memberIds is list
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds);
    }

    function isValidSelfGroupLeaveUpdate() {
      return isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'memberCount',
          'updatedAt'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.visibility == resource.data.visibility
        && request.resource.data.ownerPseudo == resource.data.ownerPseudo
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.memberIds is list
        && resource.data.memberIds is list
        && request.auth.uid in resource.data.memberIds
        && resource.data.ownerId != request.auth.uid
        && !(request.auth.uid in request.resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;
    }

    match /activities/{activityId} {
      allow get: if canReadActivity(activityId, resource.data);

      allow list: if isAuthenticated()
        && request.query.limit <= 100;

      allow create: if isValidActivityCreate();

      allow update: if isFullOwnerActivityUpdate()
        || isLimitedOwnerActivityUpdate()
        || isOperationalActivityUpdate(activityId)
        || isOwnerLeaveAndOfferOwnershipUpdate(activityId)
        || isActivityOwnershipClaimUpdate(activityId);

      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid
        && resource.data.participantCount <= 1;

      match /participants/{userId} {
        allow read: if isAuthenticated()
          && (
            isActivityOwner(activityId)
            || isParticipant(activityId)
            || isSelf(userId)
          );

        allow create: if isAuthenticated()
          && isSelf(userId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'userId',
            'pseudo',
            'joinedAt'
          ]);

        allow delete: if isAuthenticated()
          && (
            isSelf(userId)
            || isActivityOwner(activityId)
          );

        allow update: if false;
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && isActivityMember(activityId);

        allow create: if isValidTextMessageCreate(activityId)
          || isActivitySystemMessageCreate(activityId);

        allow update: if false;

        allow delete: if isAuthenticated()
          && isActivityOwner(activityId);
      }

      match /messageReads/{userId} {
        allow read, write: if isSelf(userId)
          && isActivityMember(activityId);
      }
    }

    match /users/{userId} {
      allow get: if isAuthenticated();

      allow list: if isAuthenticated()
        && request.query.limit <= 50;

      allow create: if isSelf(userId);

      allow update: if isSelf(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pseudo',
          'prenom',
          'nom',
          'lieu',
          'Lieu',
          'genre',
          'photoUrl',
          'bio',
          'favoriteCategories',
          'dateNaissance',
          'updatedAt'
        ]);

      allow delete: if isSelf(userId);

      match /devices/{deviceId} {
        allow read, write: if isSelf(userId);
      }

      match /joined_activities/{activityId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /activity_invitations/{invitationId} {
      allow read: if isInvitationParticipant()
        || (
          isAuthenticated()
          && resource.data.activityId is string
          && isActivityOwner(resource.data.activityId)
        );

      allow list: if isAuthenticated()
        && request.query.limit <= 50;

      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending'
        && isValidStatus(request.resource.data.status)
        && request.resource.data.activityId is string
        && isActivityOwner(request.resource.data.activityId);

      allow update: if isInvitationResponseUpdate()
        || isInvitationCancelUpdate();

      allow delete: if isInvitationParticipant()
        || (
          isAuthenticated()
          && resource.data.activityId is string
          && isActivityOwner(resource.data.activityId)
        );
    }

    match /group_invitations/{invitationId} {
      allow read: if isGroupInvitationParticipant();

      allow list: if isAuthenticated()
        && request.query.limit <= 50;

      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending'
        && isValidStatus(request.resource.data.status)
        && request.resource.data.groupId is string
        && (
          isGroupOwner(request.resource.data.groupId)
          || isGroupMemberById(request.resource.data.groupId)
        );

      allow update: if isGroupInvitationResponseUpdate()
        || isGroupInvitationCancelUpdate();

      allow delete: if isGroupInvitationParticipant()
        || (
          isAuthenticated()
          && resource.data.groupId is string
          && isGroupOwner(resource.data.groupId)
        );
    }

    match /friendships/{friendshipId} {
      allow create: if isAuthenticated()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.addresseeId != request.auth.uid
        && request.resource.data.status == 'pending';

      allow read: if isAuthenticated()
        && (
          resource.data.requesterId == request.auth.uid
          || resource.data.addresseeId == request.auth.uid
        );

      allow update: if isAuthenticated()
        && resource.data.addresseeId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'respondedAt',
          'updatedAt'
        ])
        && (
          request.resource.data.status == 'accepted'
          || request.resource.data.status == 'refused'
        );

      allow delete: if isAuthenticated()
        && (
          resource.data.requesterId == request.auth.uid
          || resource.data.addresseeId == request.auth.uid
        );
    }

    match /availabilities/{availabilityId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /searches/{searchId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow get: if canReadGroup(resource.data);

      allow list: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.auth.uid in request.resource.data.memberIds;

      allow update: if isOwnerGroupUpdate()
        || isValidSelfGroupJoinUpdate()
        || isValidSelfGroupLeaveUpdate();

      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      match /members/{userId} {
        allow read: if isAuthenticated()
          && (
            isGroupMemberById(groupId)
            || isGroupOwner(groupId)
            || isSelf(userId)
          );

        allow create: if isAuthenticated()
          && (
            isGroupOwner(groupId)
            || isSelf(userId)
          )
          && request.resource.data.userId == userId
          && request.resource.data.keys().hasOnly([
            'userId',
            'pseudo',
            'role',
            'joinedAt'
          ]);

        allow delete: if isAuthenticated()
          && (
            isGroupOwner(groupId)
            || isSelf(userId)
          );

        allow update: if false;
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && isGroupMemberById(groupId);

        allow create: if isAuthenticated()
          && isGroupMemberById(groupId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.type == 'user'
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;

        allow update, delete: if false;
      }

      match /messageReads/{userId} {
        allow read, write: if isSelf(userId)
          && isGroupMemberById(groupId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}